#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/vite@7.3.2_@types+node@20.19.39_tsx@4.21.0/node_modules/vite/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/vite@7.3.2_@types+node@20.19.39_tsx@4.21.0/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/vite@7.3.2_@types+node@20.19.39_tsx@4.21.0/node_modules/vite/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/vite@7.3.2_@types+node@20.19.39_tsx@4.21.0/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/vite.js" "$@"
else
  exec node  "$basedir/../../bin/vite.js" "$@"
fi
