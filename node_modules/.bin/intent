#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/@trpc+server@11.16.0_typescript@5.9.3/node_modules/@trpc/server/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/@trpc+server@11.16.0_typescript@5.9.3/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/@trpc+server@11.16.0_typescript@5.9.3/node_modules/@trpc/server/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/@trpc+server@11.16.0_typescript@5.9.3/node_modules:/home/ubuntu/better-daze-dashboard/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/@trpc+server@11.16.0_typescript@5.9.3/node_modules/@trpc/server/bin/intent.js" "$@"
else
  exec node  "$basedir/../.pnpm/@trpc+server@11.16.0_typescript@5.9.3/node_modules/@trpc/server/bin/intent.js" "$@"
fi
